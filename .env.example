# H_Tracker — environment variable reference
# Copy this file to azure.env (for Docker) or Backend/.env (for local dev).
# NEVER commit files containing real secrets.
#
# Docker usage:
#   docker-compose --env-file azure.env up -d
#
# Local backend (non-Docker):
#   cp .env.example Backend/.env   (then edit as needed)

# ── Auth mode ─────────────────────────────────────────────────────────────────
# "azure"  — validate JWTs via Entra ID JWKS (production default)
# "mock"   — skip auth entirely (local dev only; forbidden when ENV=prod)
AUTH_MODE=azure

# ── Runtime environment ───────────────────────────────────────────────────────
ENV=dev
SQL_ECHO=false

# ── Database ──────────────────────────────────────────────────────────────────
# Local (non-Docker): postgres runs on 5433 (mapped in docker-compose)
# Inside Docker Compose: use the service name and internal port 5432
DATABASE_URL=postgresql://hours_user:hours_pass@localhost:5433/hours_tracker

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Azure Entra ID — Backend App Registration ─────────────────────────────────
# App registration that EXPOSES the API scope (hours-trackerAPI back).
# The backend uses this to validate incoming JWTs via the public JWKS endpoint.
# No client secret is required — token validation uses RS256 public keys only.
AZURE_APP_CLIENT_ID=6cda0fcc-09b3-4173-b6cc-07df8bf2b82b
AZURE_TENANT_ID=9a347a67-e3c3-4de7-9c88-449af6f6c092
AZURE_API_SCOPE=api://6cda0fcc-09b3-4173-b6cc-07df8bf2b82b/user_impersonation

# Separate SPA client ID used by Swagger UI's built-in OAuth2 PKCE flow
AZURE_SWAGGER_CLIENT_ID=b44bcf9e-cc38-4542-82b9-e9447a45a7ec

# ── Azure Entra ID — Frontend SPA App Registration ────────────────────────────
# These VITE_* vars are baked into the frontend bundle at build time by Vite.
# In Docker, they are passed as build args (see docker-compose.yml → frontend.build.args).
# In local (non-Docker) dev, place them in Frontend/.env.
#
# Auth mode for the frontend (mirrors AUTH_MODE above)
VITE_AUTH_MODE=azure

# Client ID of the SPA app registration (hours-tracker front).
# Public client — PKCE flow — no secret required.
VITE_AZURE_CLIENT_ID=b44bcf9e-cc38-4542-82b9-e9447a45a7ec
VITE_AZURE_TENANT_ID=9a347a67-e3c3-4de7-9c88-449af6f6c092

# Redirect URI — must match a URI registered under Authentication → SPA in Azure Portal.
# Local dev:   http://localhost:3000
# Production:  https://<your-production-domain>   ← add this URI in Azure Portal before deploying
VITE_AZURE_REDIRECT_URI=http://localhost:3000
VITE_APP_URL=https://your-production-domain.com

# API scope requested by MSAL when acquiring tokens
VITE_AZURE_API_SCOPE=api://6cda0fcc-09b3-4173-b6cc-07df8bf2b82b/user_impersonation

# ── Expensify Partner API ──────────────────────────────────────────────────────
EXPENSIFY_PARTNER_USER_ID=
EXPENSIFY_PARTNER_USER_SECRET=

# ── FreshSales CRM API ────────────────────────────────────────────────────────
FRESHSALES_DOMAIN=yourcompany
FRESHSALES_API_KEY=your_freshsales_api_key_here

# ── Exchange rates ─────────────────────────────────────────────────────────────
COP_TO_USD_RATE=4200
EUR_TO_USD_RATE=1.08
